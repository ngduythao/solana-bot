[Unit]
Description=Solbot Panel (localhost)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/solbot
Environment=PYTHONUNBUFFERED=1
ExecStart=/bin/bash -lc 'cd %h/solbot && ./scripts/serve_dashboard.sh && ./scripts/panel_watchdog.sh'
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
