ENABLE_BINANCE=false
BINANCE_API_KEY=
BINANCE_API_SECRET=
ENABLE_BYBIT=false
BYBIT_API_KEY=
BYBIT_API_SECRET=

DAILY_LOSS_CAP_BPS=100
OPS_FEE_BURN_CAP=0.4
CROSS_SIZE_USD=400
CROSS_EV_THR_BPS=7
