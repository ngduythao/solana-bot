# ====== Solbot Safe Preset (.env) ======
# Mục tiêu: an toàn, ít rủi ro, chi phí tip thấp — phù hợp chạy thử/đêm

# RPC / WS (có thể chạy tạm bằng public; khuyến nghị RPC private để ổn định hơn)
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
WS_ENDPOINT=wss://api.mainnet-beta.solana.com

# Jupiter / Jito (tip nhỏ hơn, step lớn hơn -> ít spam bundle)
HELIUS_API_KEY=
JITO_AUTH=
JITO_RELAYS=https://ny.mainnet.block-engine.jito.wtf,https://va.mainnet.block-engine.jito.wtf
JITO_TIP_MIN=0.00005
JITO_TIP_MAX=0.0005
JITO_TIP_STEP=0.00005

# Allowlist / Denylist (giảm phạm vi giao dịch)
ROUTE_ALLOWLIST=*
ROUTE_DENYLIST=

# Hedge / Risk (bảo thủ hơn)
HEDGE_ENABLED=true
HEDGE_TARGET_RATIO=0.70
HEDGE_COOLDOWN_S=8
KELLY_CAP=0.10

# Panel
PANEL_PORT=8080

# Alerts (khuyến nghị bật để theo dõi)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

TELEGRAM_CHAT_IDS=
TELEGRAM_BOT_TOKEN=

# Base currency for accounting & inventory
BASE_ASSET=USDC

# Minimal SOL to keep for fees/tip
GAS_RESERVE_SOL=0.8

# Convert-to-Base config
CONVERT_SLIPPAGE_BPS=30
CONVERT_TOKENS=auto

# Auto-convert: off | daily | always
AUTO_CONVERT_MODE=off
AUTO_CONVERT_HOUR=7

DAILY_STOP_LOSS_PCT=3

ANTI_PVP=on
