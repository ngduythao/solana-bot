# ====== Solbot LowLatency Preset (.env) ======
# RPC / WS (ưu tiên RPC private tốc độ cao, gần datacenter)
RPC_ENDPOINT=https://rpc.lowlatency.example
WS_ENDPOINT=wss://ws.lowlatency.example

# Jupiter / Jito cấu hình thiên về tốc độ
HELIUS_API_KEY=
JITO_AUTH=
JITO_RELAYS=https://ny.mainnet.block-engine.jito.wtf,https://va.mainnet.block-engine.jito.wtf,https://sg.mainnet.block-engine.jito.wtf
# Tip cao hơn, step nhỏ để đẩy nhanh tốc độ bundle
JITO_TIP_MIN=0.0005
JITO_TIP_MAX=0.0050
JITO_TIP_STEP=0.0001

# Allowlist / Denylist
ROUTE_ALLOWLIST=*
ROUTE_DENYLIST=

# Hedge / Risk (ưu tiên tốc độ, giảm cap Kelly để tránh over-risk)
HEDGE_ENABLED=true
HEDGE_TARGET_RATIO=0.50
HEDGE_COOLDOWN_S=2
KELLY_CAP=0.15

# Panel
PANEL_PORT=8080

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

TELEGRAM_CHAT_IDS=
TELEGRAM_BOT_TOKEN=

# Base currency for accounting & inventory
BASE_ASSET=USDC

# Minimal SOL to keep for fees/tip
GAS_RESERVE_SOL=0.8

# Convert-to-Base config
CONVERT_SLIPPAGE_BPS=30
CONVERT_TOKENS=auto

# Auto-convert: off | daily | always
AUTO_CONVERT_MODE=off
AUTO_CONVERT_HOUR=7

DAILY_STOP_LOSS_PCT=3

ANTI_PVP=on
