
# ===== solbot presets: VULTR_BM_PERF (NJ) =====
# Target: Vultr Bare Metal Performance (8c ~5GHz, 64GB, 10GbE), New Jersey/DC US
# Note: replace <PRIVATE_IP> if you run local RPC.

# Infra
RPC_CANDIDATES=http://127.0.0.1:8899
JITO_RELAYS_CANDIDATES=wss://ny.relay1.jito.wtf,wss://ny.relay2.jito.wtf,wss://ny.relay3.jito.wtf
REDIS_URL=redis://localhost:6379/0
METRICS_PATH=metrics.csv

# Risk & sizing
DAILY_LOSS_LIMIT_USD=-600
BASE_ORDER_USD=60
MIN_USD=15
MAX_USD=700

# Hedge base
HEDGE_EXPO_THRESH_USD=200
HEDGE_RATIO=0.6
HEDGE_SLIPPAGE_BPS=80
HEDGE_MAX_SLIPPAGE_BPS=180
HEDGE_ONLY_USDC_OUT=true
HEDGE_TIMEOUT_CHAIN=2.0,2.5,3.0
HEDGE_PRIO_MULT=0.55
HEDGE_COOLDOWN_SEC=2
HEDGE_MIN_FILL_PCT=0.7
HEDGE_MIN_NOTIONAL_USD=30
HEDGE_MAX_ORDERS_PER_MIN=35

# Per-mint tuning for 4 pairs
HEDGE_RATIO_MAP=SOL:0.5,JUP:0.6,WIF:0.7,BONK:0.65
HEDGE_PER_MINT_LIMIT_USD=SOL:2000,JUP:1500,WIF:800,BONK:1000
HEDGE_MIN_INTERVAL_SEC=2
HEDGE_MIN_INTERVAL_SEC_MAP=SOL:2,JUP:3,WIF:4,BONK:3

# Route policy
HEDGE_ROUTE_ALLOWLIST=JUP,ORCA,RAYDIUM,PHOENIX
HEDGE_ROUTE_BLACKLIST=UNKNOWNDEX
EV_MIN_EDGE_BPS=6
EV_MAX_SLIP_P95_BPS=140
EV_MAX_LAT_P95_MS=140
EV_CAP_PER_TRADE_USD=500
KELLY_ENABLE=1
SIM_ENABLE=1
GAS_PRICE_CAP_MICROLAMPORTS=1500
JITO_TIP_MULT_BASE=0.6

DAILY_STOP_LOSS_PCT=3

ANTI_PVP=on
