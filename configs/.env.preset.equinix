
# ===== solbot presets: EQUINIX_METAL_ASHBURN (NY4/Ashburn) =====
# Tips:
# - Điền RPC private gần DC, RTT 2–5ms
# - JITO relays gần Ashburn/NY4 (>=3)
# - Bật jumbo frames (MTU 9000) nếu DC hỗ trợ

# Infra
RPC_CANDIDATES=https://rpc-private-ash1.example.com,https://rpc-private-ash2.example.com
JITO_RELAYS_CANDIDATES=wss://relay-ash1.example.com,wss://relay-ash2.example.com,wss://relay-ny4.example.com
REDIS_URL=redis://localhost:6379/0
METRICS_PATH=metrics.csv

# Risk & sizing (tốc độ cao, thanh khoản sâu)
DAILY_LOSS_LIMIT_USD=-800
BASE_ORDER_USD=90
MIN_USD=20
MAX_USD=1200

# Hedge tuned for low-latency DC
HEDGE_EXPO_THRESH_USD=250
HEDGE_RATIO=0.55
HEDGE_RATIO_MAP=SOL:0.65,USDT:0.55,JUP:0.6
HEDGE_PER_MINT_LIMIT_USD=SOL:2500,USDT:4000,JUP:1500
HEDGE_MIN_INTERVAL_SEC=1
HEDGE_MIN_INTERVAL_SEC_MAP=SOL:1,USDT:1,JUP:1
HEDGE_MIN_NOTIONAL_USD=40
HEDGE_MAX_ORDERS_PER_MIN=60

# Low slip but adaptive (policy service sẽ tự nới khi vol cao)
HEDGE_SLIPPAGE_BPS=60
HEDGE_MAX_SLIPPAGE_BPS=140
HEDGE_ONLY_USDC_OUT=true
HEDGE_TIMEOUT_CHAIN=1.6,2.0,2.4
HEDGE_PRIO_MULT=0.70
HEDGE_COOLDOWN_SEC=1
HEDGE_MIN_FILL_PCT=0.8
HEDGE_ROUTE_ALLOWLIST=JUP,ORCA,PHOENIX,RAYDIUM
HEDGE_ROUTE_BLACKLIST=

# Jito autotune chạy nền -> không cần set tay hsbot:cfg:jito_tip_*
EV_MIN_EDGE_BPS=6
EV_MAX_SLIP_P95_BPS=140
EV_MAX_LAT_P95_MS=140
EV_CAP_PER_TRADE_USD=500
KELLY_ENABLE=1
SIM_ENABLE=1
GAS_PRICE_CAP_MICROLAMPORTS=1500
JITO_TIP_MULT_BASE=0.6

DAILY_STOP_LOSS_PCT=3

ANTI_PVP=on
