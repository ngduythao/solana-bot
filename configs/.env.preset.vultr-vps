
# ===== solbot presets: VULTR_VPS (Ubuntu 24.04 LTS) =====
# Dành cho Cloud Compute / VPS (không phải Bare Metal). Tham số thận trọng hơn.
# Hãy giữ notional nhỏ, timeout nới hơn, và rate-limit chặt.

# Infra
RPC_CANDIDATES=https://mainnet.helius-rpc.com/?api-key=<YOUR_KEY>
JITO_RELAYS_CANDIDATES=wss://ny.relay1.jito.wtf,wss://ny.relay2.jito.wtf,wss://ny.relay3.jito.wtf
REDIS_URL=redis://localhost:6379/0
METRICS_PATH=metrics.csv

# Risk & sizing
DAILY_LOSS_LIMIT_USD=-300
BASE_ORDER_USD=30
MIN_USD=10
MAX_USD=300

# Hedge base (conservative)
HEDGE_EXPO_THRESH_USD=120
HEDGE_RATIO=0.55
HEDGE_SLIPPAGE_BPS=100
HEDGE_MAX_SLIPPAGE_BPS=220
HEDGE_ONLY_USDC_OUT=true
HEDGE_TIMEOUT_CHAIN=2.2,2.8,3.5
HEDGE_PRIO_MULT=0.5
HEDGE_COOLDOWN_SEC=3
HEDGE_MIN_FILL_PCT=0.7
HEDGE_MIN_NOTIONAL_USD=20
HEDGE_MAX_ORDERS_PER_MIN=20

# Per-mint tuning for 4 pairs
HEDGE_RATIO_MAP=SOL:0.5,JUP:0.55,WIF:0.65,BONK:0.6
HEDGE_PER_MINT_LIMIT_USD=SOL:800,JUP:700,WIF:400,BONK:500
HEDGE_MIN_INTERVAL_SEC=3
HEDGE_MIN_INTERVAL_SEC_MAP=SOL:3,JUP:4,WIF:5,BONK:4

# Route policy
HEDGE_ROUTE_ALLOWLIST=JUP,ORCA,RAYDIUM,PHOENIX
HEDGE_ROUTE_BLACKLIST=UNKNOWNDEX

# Notional Guard (auto giảm khối lượng khi p95 latency cao)
NOTIONAL_GUARD_ENABLE=1
GUARD_BASE_MIN_NOTIONAL_USD=20
GUARD_BASE_PER_MINT_LIMIT_USD_MAP=SOL:800,JUP:700,WIF:400,BONK:500
ROUTE_PENALTY_P95_SLIP_BPS=140
EV_MIN_EDGE_BPS=6
EV_MAX_SLIP_P95_BPS=140
EV_MAX_LAT_P95_MS=140
EV_CAP_PER_TRADE_USD=500
KELLY_ENABLE=1
SIM_ENABLE=1
GAS_PRICE_CAP_MICROLAMPORTS=1500
JITO_TIP_MULT_BASE=0.6

DAILY_STOP_LOSS_PCT=3

ANTI_PVP=on
