ENABLE_BINANCE=false
BINANCE_API_KEY=
BINANCE_API_SECRET=
ENABLE_BYBIT=false
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ===== Risk caps =====
DAILY_LOSS_CAP_BPS=100     # -1% NAV auto-pause
OPS_FEE_BURN_CAP=0.4       # 40% gross/day
CROSS_SIZE_USD=400         # initial sizing
CROSS_EV_THR_BPS=7         # conservative EV threshold
