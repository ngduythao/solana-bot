##### Cross-venue defaults (safe start) #####
# Start small & conservative, tune after accept/reject observed:
CROSS_SIZE_USD=400
CROSS_EV_THR_BPS=7
CROSS_SLIPPAGE_BPS=15
CROSS_ONLY_DIRECT=true
# Routes to watch (CEX:DEX)
CROSS_ROUTES=SOLUSDT:SOL/USDC,JUPUSDT:JUP/USDC,WIFUSDT:WIF/USDC,BONKUSDT:BONK/USDC
# Reference venues order
CROSS_VENUE=BINANCE,BYBIT



##### Fee burn guard #####
# If daily priority-fee burn exceeds this ratio of gross PnL (0.30~0.40), reduce size or pause.
FEE_BURN_MAX_RATIO=0.40
# Action when cap exceeded: reduce or pause
FEE_BURN_ACTION=reduce  # values: reduce | pause
# When reduce: new size multiplier (e.g., 0.5 halves the size)
FEE_BURN_REDUCE_MULT=0.5


# Dùng RPC gateway nội bộ (auto-switch best endpoint sau Benchmark)
RPC_PRIMARY=http://rpc-gateway:8899

# Simulator HTTP endpoint
SIM_ENDPOINT=http://sim-server:9000
SIM_GATE_EV_THR_BPS=3
SIM_GATE_MAX_HOPS=3


# Jito multi-relay
JITO_MODE=grpc
JITO_ENDPOINTS=grpc://relay1:10000,grpc://relay2:10000
JITO_AUTH_TOKEN=

# Signer
SIGNER_KEY_PATH=/run/secrets/solana_keypair_hex
SIGNER_RATE_QPS=20

# Ops guard
OPS_RPC_P95_THR=150
OPS_ACCEPT_THR=0.6
OPS_LOSS_CAP=-0.01

# Backtest
BACKTEST_DAYS=1
BACKTEST_OUT=/app/backtest/pnl_daily.csv

# ==== Hedge settings ====
HEDGE_INTERVAL_SEC=300
INVENTORY_SKEW_CAP=0.1
HEDGE_MIN_NOTIONAL_USD=25

# ==== Fee burn cap ====
OPS_FEE_BURN_CAP=0.4

# ===== RPC & Jito =====
RPC_PRIMARY=https://mainnet.helius.rpcpool.com/?api-key=<YOUR_HELIUS_KEY>
RPC_FALLBACK_1=https://api.mainnet-beta.solana.com
RPC_FALLBACK_2=https://rpc.solana.wtf/
RPC_FALLBACK_3=https://<your-private-rpc-near-datacenter>

JITO_MODE=grpc
JITO_ENDPOINTS=grpc://ny.mainnet.jito.wtf:10000,grpc://va.mainnet.jito.wtf:10000,grpc://sjc.mainnet.jito.wtf:10000
JITO_API_KEY=

