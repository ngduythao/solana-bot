
# ===================== Solbot .env (Final Template) =====================
# Copy via:  bash solana-bot/deploy/APPLY_ENV_TEMPLATE.sh
# Or copy this file to /etc/solbot/.env and `chmod 600 /etc/solbot/.env`
#
# --- Core ---
REDIS_URL=redis://localhost:6379/0
RPC_PRIMARY=https://api.mainnet-beta.solana.com
REGION=nj-us            # nj-us or sg-apac (just a label for logs/metrics)

# --- Jito (relays; comma-separated hostnames) ---
# Suggest: NJ node => NY/NJ first; SG node => SG/TYO first
JITO_RELAYS=newyork.mainnet.block-engine.jito.wtf,newjersey.mainnet.block-engine.jito.wtf,singapore.mainnet.block-engine.jito.wtf,tokyo.mainnet.block-engine.jito.wtf
# If you have tip stream endpoints, add them:
TIP_STREAM_URL=         # optional
TIP_FLOOR_URL=          # optional

# --- Keys ---
MAKER_KEYPAIR=/etc/solbot/maker.json     # MUST exist and have chmod 600
#JITO_KEYPAIR=/etc/solbot/jito.json      # optional; if using BE key auth

# --- Fee Policy (defaults safe; Autopilot will tune) ---
FEE_ALPHA=1.5
FEE_BETA_LAT=0.15
FEE_GAMMA_ACC=0.25
FEE_DELTA_P95=0.10

# --- Autopilot targets ---
PAL_TARGET_ACCEPT=0.55
PAL_TARGET_EV=200000

# --- Canary / Fallback ---
ENABLE_CANARY=0           # 1 to enable private canary tx
PUBLIC_RPC_FALLBACK=0  # DO NOT enable in stealth mode     # 1 to allow public sendTransaction fallback (NOT recommended)

# --- Ops ---
LOG_LEVEL=INFO
HEALTH_PORT=9090

# --- Optional hedging ---
FUNDING_BPS=1.0
WITHDRAW_FEE=5000
BRIDGE_FEE=10000


# --- Alerts (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Public RPC fallback IP whitelist (comma-separated) ---
PUBLIC_FALLBACK_WHITELIST=127.0.0.1,::1


# --- Error tracking (optional) ---
SENTRY_DSN=
ROLLBAR_TOKEN=

# --- RPC candidates list for rotator (comma-separated) ---
RPC_CANDIDATES=https://api.mainnet-beta.solana.com

# Online A/B exploration rate
AB_EXP_RATE=0.1

# Allocator limits
ALLOC_MAX_MULT=3.0
ALLOC_MIN_MULT=0.2
BASE_SIZE_Q0=500000

# Kill-switch thresholds
KILL_P95_MS=1600
KILL_MISS=0.40


# --- FastPath executor ---
FAST_STAGGER_US=700
FAST_MAX_RELAYS=2
FAST_LOG=0


# --- Capital Planner ---
CAP_TOTAL_Q0=6000000
REGIONS=nj-us,sg-apac

# --- Fee Optimizer ---
FEE_MIN_TIP=5000
FEE_MAX_TIP=500000
DEX_MIN_FEE_BPS=5
DEX_MAX_FEE_BPS=80

# --- Hedge (optional) ---
HEDGE_ENABLE=0
HEDGE_MAX_USD=0


# --- Budget Guardrails (daily) ---
GUARD_DAILY_TIP_LAMPORTS=200000000
GUARD_DAILY_DEX_FEE=50
GUARD_DAILY_SLIP_BPS=1000


# --- Rebalance ---
REBALANCE_THRESH_PCT=0.60


# --- Rebalance & Budget ---
REBAL_THRESH=0.6
BUDGET_TIP_DAY=200000000
BUDGET_FEE_DAY=100000000

# --- Tip-stream (optional) ---
TIP_STREAM_URL=


# --- Security & Stealth ---
ADMIN_IP_WHITELIST=           # comma-separated IPs for dashboard access
DASH_AUTH_TOKEN=              # if set, /pro requires this token via ?token= or X-Auth-Token
STRATEGY_FERNET_KEY=          # optional: encrypt strategy.yaml at rest
ENABLE_HONEYPOT=0
HONEYPOT_PORT=10025


# --- Treasury Mastery ---
SOL_GAS_MIN=0.5
SOL_GAS_TARGET=1.5
VAULT_RATIO=0.3


# --- Profit Compounding ---
COMPOUND_STEP=0.10
COMPOUND_MAX_HOT=0.45
COMPOUND_DD_SOFT=-500
COMPOUND_DD_HARD=-2000
ROLLING_PNL_ALPHA=0.2

# --- Daily Budgets ---
BUDGET_TIP_LAMPORTS=250000000
BUDGET_DEX_FEE=80
BUDGET_SLIP_BPS=1200


# --- Executor mode ---
SIGNER_MODE=paper        # paper | hot
KEYPAIR_PATH=/etc/solbot/solana.json


# --- Bridge / Executor wiring ---
BRIDGE_ENABLE=0
RPC_URL=


# --- Jupiter HOT safety ---
JUP_ALLOWED_MINTS=USDC,SOL
JUP_MAX_SLIPPAGE_BPS=80
JUP_RATE_LIMIT_PER_MIN=20
JUP_DAILY_USDC_CAP=5000
USDC_DECIMALS=6
SOL_USDC_PRICE_HINT=100

# --- Relay tip-curve ---
RELAYS_CANDIDATES=relay_sg_1,relay_sg_2,relay_nj_1,relay_nj_2


# --- Jupiter SDK real swap ---
JUP_SDK_ENABLE=0


# --- Relay SLO aggregator ---
SLO_WINDOW=1200


# --- Jupiter real client (Jup.AG v6) ---
JUP_REAL=0
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOL_MINT=So11111111111111111111111111111111111111112

# --- Bridge budgets ---
BRIDGE_DAILY_USDC_CAP=20000
BRIDGE_RATE_LIMIT_PER_HOUR=20

COLO_TARGETS=ny.solana.com sg.solana.com jp.solana.com


# --- Wormhole bridge real wiring ---
WORMHOLE_CLI=wormhole
WH_SRC_CHAIN=solana
WH_DST_CHAIN=solana
WH_DST_WALLET=/etc/solbot/solana.json
BRIDGE_DRY_RUN=1
BRIDGE_RETRY_MAX=3
BRIDGE_RETRY_BACKOFF=2.0

# --- Co-lo RTT targets ---
COLO_RTT_TARGETS=api.mainnet-beta.solana.com:443,ny.relay.example:10001,sg.relay.example:10001
COLO_RTT_TIMEOUT=0.35
COLO_RTT_INTERVAL=5


# --- Circuit Breaker & Health ---
CB_P95_MAX_MS=1800
CB_MISS_SLOT_MAX=0.25
CB_DD_HARD=-3000
CB_TIP_LAM_MAX=800000000
CB_ARM_TIMEOUT=600

HLTH_DISK_FREE_MIN=2.0
HLTH_MEM_FREE_MIN=0.3
