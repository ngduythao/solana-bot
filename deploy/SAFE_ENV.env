
# SAFE_ENV.env — fill values before running prod

# Redis
REDIS_URL=redis://localhost:6379/0

# RPC primary
RPC_PRIMARY=https://api.mainnet-beta.solana.com

# Jito relays (comma-separated)
JITO_RELAYS=newyork.mainnet.block-engine.jito.wtf,singapore.mainnet.block-engine.jito.wtf

# Maker keypair path (JSON format) — chmod 600 required
MAKER_KEYPAIR=/etc/solbot/maker.json

# Jito keypair path (optional, if BE Auth)
# JITO_KEYPAIR=/etc/solbot/jito.json

# Region tag
REGION=prod-nj-or-sg

# Optional funding penalties
FUNDING_BPS=1.0
WITHDRAW_FEE=5000
BRIDGE_FEE=10000
